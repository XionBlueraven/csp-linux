#!/bin/bash

# CSP launcher — uses Wine Staging with the prefix written by csp-installer.sh
# Updated by xion

CSPRC="$HOME/.config/csprc"

if [ ! -f "$CSPRC" ]; then
    echo "csprc not found. Please run csp-installer.sh first." 1>&2
    exit 1
fi

export WINEPREFIX=$(grep '^WINEPREFIX=' "$CSPRC" | cut -d '=' -f 2)
export WINEARCH=$(grep '^WINEARCH=' "$CSPRC" | cut -d '=' -f 2)

if [ -z "$WINEPREFIX" ]; then
    echo "WINEPREFIX not set in $CSPRC" 1>&2
    exit 1
fi

CSP_EXE="$WINEPREFIX/drive_c/Program Files/CELSYS/CLIP STUDIO 1.5/CLIP STUDIO PAINT/CLIPStudioPaint.exe"

if [ ! -f "$CSP_EXE" ]; then
    echo "CLIPStudioPaint.exe not found at:" 1>&2
    echo "  $CSP_EXE" 1>&2
    echo "Please run csp-installer.sh to install CSP first." 1>&2
    exit 1
fi

echo "Starting Clip Studio Paint..."
wine "$CSP_EXE"
